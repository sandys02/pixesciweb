# Optional local Docker overrides. docker-compose.yml also provides safe local
# defaults for session secrets so the site can start without this file.

PIXESCI_WEB_PORT=3000

DOWNLOAD_SESSION_SECRET=replace-with-at-least-32-characters
DOWNLOAD_SESSION_TTL_SECONDS=1200
DOWNLOAD_LINK_LOCK_URL=
DOWNLOAD_LINK_LOCK_PASSWORD=

PORTAL_SESSION_SECRET=replace-with-at-least-32-characters
PORTAL_SESSION_TTL_SECONDS=1200

# Leave PORTAL_DATABASE_URL empty to use the Compose volume at /data/portal.db.
# Set it for a durable remote libSQL/Turso database.
PORTAL_DATABASE_URL=
PORTAL_DATABASE_AUTH_TOKEN=

# Required for production license bundle and activation signing endpoints.
PORTAL_LICENSE_SIGNING_PRIVATE_KEY_PEM=
PORTAL_LICENSE_PUBLIC_KEY_PEM=
PORTAL_LICENSE_PUBLIC_KEY_ID=
