{
  "name": "pixesci-website",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:push": "npm run db:push:download && npm run db:push:portal",
    "db:push:download": "drizzle-kit push",
    "db:push:portal": "drizzle-kit push --config drizzle.portal.config.ts",
    "db:seed": "tsx scripts/seed-download-user.ts",
    "db:seed:portal": "tsx scripts/seed-portal-account.ts",
    "db:migrate:portal": "tsx scripts/migrate-portal-sqlite-to-libsql.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@reduxjs/toolkit": "^2.12.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.3.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
